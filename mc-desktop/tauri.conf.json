{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MonkeyCode",
  "version": "0.1.0",
  "identifier": "com.chaitin.baizhi.monkeycode",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "shell-pages",
          "description": "壳自带页面(设置/错误页)可调用壳的配置命令",
          "windows": [
            "main",
            "settings"
          ],
          "permissions": [
            "core:default",
            "allow-get-config",
            "allow-save-config",
            "allow-open-settings-window",
            "allow-close-settings"
          ]
        },
        {
          "identifier": "kernel-ui",
          "description": "主窗口加载的内核 UI(127.0.0.1 remote)可唤起壳的设置窗口",
          "windows": [
            "main"
          ],
          "remote": {
            "urls": [
              "http://127.0.0.1:*"
            ]
          },
          "permissions": [
            "core:default",
            "allow-open-settings-window",
            "dialog:allow-open"
          ]
        }
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false
  }
}
