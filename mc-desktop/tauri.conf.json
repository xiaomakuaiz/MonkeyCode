{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MonkeyCode",
  "version": "26071401.0.0",
  "identifier": "com.chaitin.baizhi.monkeycode",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "shell-pages",
          "description": "壳自带的错误页(无 command 调用,仅 core 基础能力)",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default"
          ]
        },
        {
          "identifier": "kernel-ui",
          "description": "主窗口加载的内核 UI(127.0.0.1 remote):读写壳持有的配置、原生目录选择",
          "windows": [
            "main"
          ],
          "remote": {
            "urls": [
              "http://127.0.0.1:*"
            ]
          },
          "permissions": [
            "core:default",
            "core:window:allow-start-dragging",
            "allow-get-config",
            "allow-save-config",
            "allow-host-info",
            "allow-update-check",
            "allow-update-install",
            "dialog:allow-open",
            "opener:allow-open-url",
            "opener:allow-default-urls"
          ]
        }
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0MTkzMzI3RjhCQzRFMUYKUldRZlRyejRKek1aOUpBME1rRWdvQ1JjMVYzMFlIVEQ4UVVMVmtwWTJLVnM5VHdVeGRTemUrc3kK",
      "endpoints": ["https://release.monkeycode-ai.com/public/desktop/latest.json"]
    }
  }
}
