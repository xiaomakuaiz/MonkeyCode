{
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "externalBin": [
      "binaries/ohmyagent"
    ],
    "resources": {
      "../browser-extension/dist": "browser-extension"
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://release.monkeycode-ai.com/public/desktop/latest-windows.json"
      ]
    }
  }
}
