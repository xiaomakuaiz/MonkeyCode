{
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/mc-agent"],
    "resources": {
      "../browser-extension/dist": "browser-extension",
      "binaries/mc-agent-linux": "mc-agent-linux"
    },
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://release.monkeycode-ai.com/public/desktop/latest-windows.json"]
    }
  }
}
